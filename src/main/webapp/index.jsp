<html>
<body>

<h2>Welcome to User Registration Form</h2>
<h5>Fill the below details</h5>

<form action="newForm" method="post">

    Name : <input type="text" name="name" placeholder="Enter Name" required style=" background-color:yellow"/><br>
    Age : <input type="number" name="age" placeholder="Enter Age" required style=" background-color:yellow"/><br>
    Email : <input type="email" name="email" placeholder="Enter Email" required style=" background-color:yellow"/><br>
    Phone : <input type="number" name="phone" placeholder="Enter Phone" required style=" background-color:yellow"/><br>
    Password : <input type="password" name="password" placeholder="Enter Password" required style=" background-color:yellow"/><br>
    <br>Submit : <button type="submit" style=" background-color:yellow">Submit</button>

    <h3>Thanks for Visiting</h3>
</form>
</body>
</html>
